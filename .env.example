
DEV_MODE=true          # set to skip model loading during

DEVICE=cuda            # cuda | cpu
NUM_FRAMES=16
FPS=8
WIDTH=512
HEIGHT=512
INFERENCE_STEPS=25
GUIDANCE_SCALE=7.5

ENABLE_UPSCALE=false
UPSCALE_FACTOR=2

# FAL_API_KEY=           # fal.ai key for GPU fallback
# OPENAI_API_KEY=        # optional: GPT-4 prompt expansion




# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── Optional overrides ────────────────────────────────────────────────────────
# DEV_MODE=true       # skip model loading, return test frames instantly
# DEVICE=cuda         # force device: cuda | mps | cpu (auto-detected if unset)

# Generation settings — defaults are tuned for MPS (Mac Apple Silicon)
# On a cloud GPU (CUDA), use: NUM_FRAMES=16, WIDTH=512, HEIGHT=512, INFERENCE_STEPS=25
# NUM_FRAMES=16
# FPS=8
# WIDTH=384
# HEIGHT=384
# INFERENCE_STEPS=15
# GUIDANCE_SCALE=7.5

# Model checkpoints — defaults work well, only change if you want a different style
# BASE_SD_MODEL=Lykon/DreamShaper
# ANIMATEDIFF_MOTION_ADAPTER=guoyww/animatediff-motion-adapter-v1-5-3